# Copy this to .env and fill in real values — never commit .env
APP_NAME=SkyWatch NTN
APP_VERSION=1.0.0
DEBUG=False
DATABASE_URL=postgresql://skywatch:CHANGE_ME@localhost:5432/skywatch_db
REDIS_URL=redis://localhost:6379
ADMIN_API_KEY=sw-admin-CHANGE_ME_MIN_32_CHARS
DEVICE_API_KEY=sw-device-CHANGE_ME_MIN_32_CHARS
RATE_LIMIT_PER_MINUTE=300
TOTAL_DEVICES=500
SIMULATION_INTERVAL_SECONDS=1.0
